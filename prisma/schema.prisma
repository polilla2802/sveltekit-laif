generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model User {
  id    BigInt  @id @default(autoincrement())
  email String  @unique
  name  String?
}

model VideoUrl {
  id           String @id
  mainVideoSrc String
  altVideoSrc  String
}

model Presence {
  id       String   @id
  path     String
  lastSeen DateTime @default(now())
}
